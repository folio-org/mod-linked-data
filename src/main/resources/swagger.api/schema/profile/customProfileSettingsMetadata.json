{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "Custom profile settings metadata",
  "type": "object",
  "allOf": [
    {
      "$ref": "customProfileSettingsLabel.json"
    },
    {
      "properties": {
        "id": {
          "type": "integer",
          "format": "int16",
          "description": "ID of the custom profile settings"
        },
        "profileId": {
          "type": "integer",
          "format": "int16",
          "description": "ID of the profile"
        }
      },
      "required": [
        "id",
        "profileId"
      ]
    }
  ]
}
